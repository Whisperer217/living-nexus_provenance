# Living Nexus — Self-Host Environment Variables
# Copy this file to .env and fill in the values before deploying.

# ─── App Settings ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
VITE_APP_ID=living-nexus-selfhost-01
JWT_SECRET=generate_a_random_secure_string_here

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
# If using docker-compose, this matches the internal network
DATABASE_URL=mysql://living_nexus:living_nexus_pass@db:3306/living_nexus
MYSQL_ROOT_PASSWORD=change_this_root_password

# ─── Storage (MinIO / S3) ─────────────────────────────────────────────────────
# If using the included MinIO container, leave endpoint as is (or use your domain)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin_secret_change_me
S3_BUCKET=living-nexus-uploads

# ─── External APIs (Configure later via Admin Panel if preferred) ─────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=
